{
  "name": "blacksmith-studio",
  "version": "0.1.0",
  "description": "Blacksmith Studio — AI-powered development environment",
  "private": true,
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "concurrently -n client,electron -c green,magenta \"npm run dev:client\" \"npm run dev:electron\"",
    "dev:client": "vite",
    "dev:electron": "sleep 3 && electron .",
    "build:client": "vite build",
    "build:electron": "tsup --config tsup.electron.config.ts",
    "build": "npm run build:client && npm run build:electron",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win",
    "package:linux": "npm run build && electron-builder --linux",
    "build:run:dev": "npm run build:electron && npm run dev"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.23",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.2",
    "better-sqlite3": "^12.8.0",
    "blacksmith-cli": "^0.1.8",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "fix-path": "^5.0.0",
    "material-file-icons": "^2.4.0",
    "simple-git": "^3.35.2"
  },
  "devDependencies": {
    "@chakra-ui/react": "^3.34.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.0.0",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.90.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "lucide-react": "^0.400.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.55.0",
    "react-markdown": "^9.0.0",
    "react-router-dom": "^7.6.0",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "tsup": "^8.4.0",
    "typescript": "~5.8.0",
    "vite": "^6.3.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  }
}
